rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function signedIn() {
      return request.auth != null;
    }

    function userEmail() {
      return request.auth.token.email;
    }

    function memberDocumentId(storeId) {
      return storeId + "_" + userEmail();
    }

    function hasStoreAccess(storeId) {
      return signedIn()
        && firestore.exists(/databases/(default)/documents/storeMembers/$(memberDocumentId(storeId)))
        && firestore.get(/databases/(default)/documents/storeMembers/$(memberDocumentId(storeId))).data.status == "active";
    }

    match /companies/{companyId}/stores/{storeId}/{allPaths=**} {
      allow read: if hasStoreAccess(storeId);
      allow write: if hasStoreAccess(storeId)
        && request.resource.size < 8 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }
  }
}
