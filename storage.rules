rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function signedIn() {
      return request.auth != null;
    }

    function userCompanyId() {
      return firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.companyId;
    }

    function sameCompany(companyId) {
      return signedIn() && userCompanyId() == companyId;
    }

    match /companies/{companyId}/{allPaths=**} {
      allow read: if sameCompany(companyId);
      allow write: if sameCompany(companyId)
        && request.resource.size < 8 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }
  }
}
